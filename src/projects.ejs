---
layout: base.ejs
title: Projects
---

<h1>Projects</h1>

<ul class="post-list">
<%
  // Sort projects strictly by date descending
  const sortedProjects = (collections.project || []).slice().sort((a, b) => b.date - a.date);
  sortedProjects.forEach(proj => {
%>
  <li class="post-item">
    <a href="<%= proj.url %>">
      <p class="post-date"><%= proj.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></p>
      <h2><%= proj.data.title %></h2>
    </a>
  </li>
<% }); %>
</ul>
