---
layout: base.ejs
title: Writing
---

<h1>Writing</h1>

<ul class="post-list">
<%
  // Sort posts strictly by date descending
  const sortedPosts = (collections.post || []).slice().sort((a, b) => b.date - a.date);
  sortedPosts.forEach(post => {
%>
  <li class="post-item">
    <a href="<%= post.url %>">
      <p class="post-date"><%= post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></p>
      <h2><%= post.data.title %></h2>
    </a>
  </li>
<% }); %>
</ul>
